#-----------------------------------------------------------------------
# Application
#-----------------------------------------------------------------------
APP_NAME="Diet Watchers"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

#-----------------------------------------------------------------------
# Security
#-----------------------------------------------------------------------
BCRYPT_ROUNDS=12

#-----------------------------------------------------------------------
# Logging
#-----------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#-----------------------------------------------------------------------
# Database
#-----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dietwatcher
DB_USERNAME=root
DB_PASSWORD=

#-----------------------------------------------------------------------
# External API (Diet Watchers Backend)
#-----------------------------------------------------------------------
EXTERNAL_API_URL=
EXTERNAL_API_TOKEN=
# When true, checkout phone OTP uses the external app API (EXTERNAL_API_URL) and stores the returned token for addresses/payment. Set false to use local SMS OTP only.
CHECKOUT_USE_EXTERNAL_LOGIN=true

#-----------------------------------------------------------------------
# Session
#-----------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

#-----------------------------------------------------------------------
# Drivers
#-----------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

#-----------------------------------------------------------------------
# Redis (optional — used if CACHE_STORE=redis or QUEUE_CONNECTION=redis)
#-----------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#-----------------------------------------------------------------------
# Mail
#-----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dietwatchers.com"
MAIL_FROM_NAME="${APP_NAME}"

#-----------------------------------------------------------------------
# Payment Gateway (Moyasar)
# https://moyasar.com — Get keys from dashboard
#-----------------------------------------------------------------------
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=

#-----------------------------------------------------------------------
# SMS Provider (connect | mshastra)
# Used for OTP verification during checkout
#-----------------------------------------------------------------------
SMS_PROVIDER=connect

# Connect Saudi (default)
CONNECT_URL=https://sms.connectsaudi.com/sendurl.aspx
CONNECT_PROFILE_ID=
CONNECT_PASSWORD=
CONNECT_SENDER_ID=DietWatcher

# Mshastra (alternative)
MSHASTRA_URL=https://mshastra.com/sendurl.aspx
MSHASTRA_PROFILE_ID=
MSHASTRA_PASSWORD=
MSHASTRA_SENDER_ID=

#-----------------------------------------------------------------------
# AWS (optional — only if using S3 filesystem)
#-----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#-----------------------------------------------------------------------
# Vite
#-----------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#-----------------------------------------------------------------------
# Google Maps (for address picker on checkout)
#-----------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
